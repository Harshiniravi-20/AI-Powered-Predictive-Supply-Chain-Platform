    <worksheet name='Delivery Rate'>
      <table>
        <view>
          <datasources>
            <datasource caption='supply_chain (SupplyChain_AI)' name='federated.0y9car81le8d1h11x4vyn1uwx4wd' />
          </datasources>
          <datasource-dependencies datasource='federated.0y9car81le8d1h11x4vyn1uwx4wd'>
            <column caption='Delivery Rate' datatype='real' name='[Calculation_0704790168784897]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(&#13;&#10;IF [Delivery_Status] = &quot;Delivered&quot;&#13;&#10;THEN 1&#13;&#10;ELSE 0&#13;&#10;END&#13;&#10;)&#13;&#10;/ COUNT([Order_ID]) * 100' />
